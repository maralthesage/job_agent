<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  com.jobagent.plist
  ---------------------------------------------------------
  Optional macOS launchd agent.

  This starts the local Job Agent browser UI when you log in. For most users,
  running `python main.py` manually is simpler.

  INSTALLATION:
    1. Edit the paths below to match where you cloned this project.
    2. Copy to LaunchAgents:
         cp com.jobagent.plist ~/Library/LaunchAgents/
    3. Load it:
         launchctl load ~/Library/LaunchAgents/com.jobagent.plist
    4. To unload (stop):
         launchctl unload ~/Library/LaunchAgents/com.jobagent.plist
    5. To start manually right now:
         launchctl start com.jobagent
    6. Check logs:
         tail -f /tmp/job_agent.log
  ---------------------------------------------------------
-->
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.jobagent</string>

  <!-- EDIT THIS: full path to your Python in the venv -->
  <key>ProgramArguments</key>
  <array>
    <string>/Users/YOUR_USERNAME/job_agent/venv/bin/python</string>
    <string>/Users/YOUR_USERNAME/job_agent/main.py</string>
  </array>

  <!-- EDIT THIS: path to the project folder -->
  <key>WorkingDirectory</key>
  <string>/Users/YOUR_USERNAME/job_agent</string>

  <!-- Run when the LaunchAgent is loaded, usually at login. -->
  <key>RunAtLoad</key>
  <true/>

  <!-- Optional local settings. Change OLLAMA_MODEL if you use another model. -->
  <key>EnvironmentVariables</key>
  <dict>
    <key>OLLAMA_MODEL</key>
    <string>llama3.2</string>
    <key>PATH</key>
    <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/Users/YOUR_USERNAME/job_agent/venv/bin</string>
  </dict>

  <!-- Logs -->
  <key>StandardOutPath</key>
  <string>/tmp/job_agent.log</string>
  <key>StandardErrorPath</key>
  <string>/tmp/job_agent_error.log</string>

  <!-- Keep alive on crash -->
  <key>KeepAlive</key>
  <false/>

</dict>
</plist>
